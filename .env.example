# Copy this file to .env and fill in your values
# cp .env.example .env

# Database — PostgreSQL
# Format: postgres://<username>:<password>@<host>/<database>
DATABASE_URL=postgres://postgres@localhost/alkye_db

# JWT secret (must be long & random in production)
JWT_SECRET=change_me_to_a_long_random_string

# Server
HOST=0.0.0.0
PORT=3000

# Logging level
RUST_LOG=alkye_backend=info,tower_http=info
